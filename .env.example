# Webstudio Self-Host Werkstatt — Environment-Konfiguration
#
# Kopiere diese Datei nach `.env` und ersetze alle "change-me"-Werte.
# Niemals .env committen — siehe .gitignore.
#
# Pattern-Quelle: github.com/webstudio-community/webstudio-self-host
# Anpassungen: proxy-network (Caddy/Traefik vor der App), Bind-Mounts auf /data/

# ── Domain ──────────────────────────────────────────────────────────────────
# Public-Domain ueber die Caddy/Traefik die App erreicht. Webstudio prueft
# Origin gegen diesen Wert — muss exakt passen.
APP_FQDN=webstudio.example.com

# ── Reverse-Proxy-Loopback (Hairpin-NAT-Workaround) ────────────────────────
# Container-IP des Reverse-Proxy (Caddy/Traefik) im proxy-network.
# Wird in docker-compose.yml als extra_hosts-Eintrag fuer webstudio-app
# benutzt, damit der OAuth-Token-Tausch nicht ueber die public IP laeuft
# (Hairpin-NAT scheitert auf vielen Docker-Hosts mit "fetch failed").
# Volle Erklaerung: docs/REVERSE-PROXY.md, Section "Loopback-Fix".
# Ermitteln mit:
#   docker inspect <proxy-container> \
#     --format '{{(index .NetworkSettings.Networks "proxy-network").IPAddress}}'
REVERSE_PROXY_IP=172.21.0.3

# ── Builder-Image ───────────────────────────────────────────────────────────
# Community-Fork mit Self-Hosting-Patches (Production-Build, kein Vite-Dev)
BUILDER_IMAGE=ghcr.io/webstudio-community/builder:latest

# ── Database ────────────────────────────────────────────────────────────────
# Generiere mit: openssl rand -hex 32
POSTGRES_PASSWORD=change-me-strong-postgres-password

# ── PostgREST JWT-Secret ────────────────────────────────────────────────────
# Mindestens 64 Zeichen.
# Generiere mit: openssl rand -hex 64
PGRST_JWT_SECRET=change-me-64-or-more-character-pgrst-jwt-secret

# ── Webstudio Auth ──────────────────────────────────────────────────────────
# Cookie-Signing-Secret. Bei DEV_LOGIN gleichzeitig das Login-Passwort.
# Generiere mit: openssl rand -hex 32
AUTH_SECRET=change-me-32-byte-auth-secret

# DEV_LOGIN = simples Email+Passwort-Login (Passwort = AUTH_SECRET-Wert).
# Fuer Single-User-Werkstatt OK. Fuer Multi-User: GitHub/Google-OAuth einrichten.
DEV_LOGIN=true
DEV_LOGIN_EMAIL=admin@example.com

# ── Service-to-service Token ────────────────────────────────────────────────
# Auch wenn Publisher-Service nicht genutzt wird: Builder erwartet die Variable.
# Generiere mit: openssl rand -hex 32
TRPC_SERVER_API_TOKEN=change-me-trpc-token

# ── Feature Flags ───────────────────────────────────────────────────────────
FEATURES=*
USER_PLAN=Pro
MAX_ASSETS_PER_PROJECT=200

# ── MinIO (S3-kompatibler Asset-Storage) ────────────────────────────────────
MINIO_ROOT_USER=minioadmin
# Generiere mit: openssl rand -hex 24
MINIO_ROOT_PASSWORD=change-me-minio-password
S3_ENDPOINT=http://webstudio-minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change-me-minio-password
S3_BUCKET=webstudio-assets

# ── OAuth (optional, Alternative zu DEV_LOGIN) ──────────────────────────────
# GH_CLIENT_ID=
# GH_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
